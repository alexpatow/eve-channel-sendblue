# Sendblue credentials. Leave unset to run the channel in dry-run mode
# (inbound webhooks drive a real session; outbound replies are logged).
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=

# Your registered Sendblue number in E.164 format, used as the default sender.
SENDBLUE_FROM_NUMBER=+14155551234

# Optional: shared secret checked against the `sb-signing-secret` webhook header.
SENDBLUE_WEBHOOK_SECRET=

# Optional: URL Sendblue posts outbound delivery status to.
SENDBLUE_STATUS_CALLBACK_URL=

# Model provider key for the agent (see agent/agent.ts).
AI_GATEWAY_API_KEY=
