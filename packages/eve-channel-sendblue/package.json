{
  "name": "eve-channel-sendblue",
  "version": "0.1.0",
  "description": "Sendblue (iMessage/SMS) channel for the eve agent framework",
  "keywords": [
    "agent",
    "eve",
    "eve-channel",
    "imessage",
    "sendblue",
    "sms"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "sendblue": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "ai": "^7.0.0",
    "eve": "^0.19.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "ai": "^7.0.0",
    "eve": ">=0.19.0"
  }
}
